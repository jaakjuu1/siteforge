---
import siteConfig from "../../site.config";

const { services } = siteConfig.business;

const iconMap: Record<string, string> = {
  scissors:
    "M14.121 14.121L7.05 21.192a2.5 2.5 0 11-3.535-3.536l7.07-7.07m0 0L3.515 3.515a2.5 2.5 0 113.536-3.536L14.12 7.05m0 7.07l2.829-2.828m-2.829 2.829l7.07 7.07a2.5 2.5 0 11-3.535 3.536L14.12 14.12zm2.829-2.829l3.536-3.535a2.5 2.5 0 00-3.536-3.536L14.121 7.05",
  palette:
    "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01",
  sparkles:
    "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z",
  heart:
    "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  user: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
  wand: "M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z",
};
---

<section id="palvelut" class="section-padding bg-gray-50/50">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10">
    <div class="text-center mb-16 md:mb-20 reveal">
      <span class="inline-block text-sm font-semibold text-primary tracking-widest uppercase mb-4">
        Palvelut
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading text-secondary mb-5">
        Palvelumme
      </h2>
      <div class="divider-gradient w-24 mx-auto mb-6"></div>
      <p class="text-lg text-gray-500 max-w-xl mx-auto leading-relaxed">
        Tarjoamme monipuolisia hiuspalveluita ammattitaidolla ja intohimolla
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        services.map((service, i) => (
          <div
            class={`reveal reveal-delay-${Math.min(i + 1, 5)} group card-hover bg-white rounded-2xl p-8 lg:p-10 border border-gray-100/80`}
            style={`box-shadow: var(--shadow-sm)`}
          >
            <div
              class="w-14 h-14 rounded-2xl flex items-center justify-center mb-7 transition-all duration-400 bg-primary/8 group-hover:bg-primary group-hover:shadow-lg"
              style="transition-timing-function: var(--ease-out-expo)"
            >
              <svg
                class="w-6 h-6 text-primary transition-colors duration-400 group-hover:text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={iconMap[service.icon] || iconMap.heart}
                />
              </svg>
            </div>
            <h3 class="text-xl font-bold font-heading text-secondary mb-3 group-hover:text-primary transition-colors duration-300">
              {service.title}
            </h3>
            <p class="text-gray-500 leading-relaxed text-[0.95rem]">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
