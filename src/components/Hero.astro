---
import siteConfig from "../../site.config";

const { business } = siteConfig;
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-secondary">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <img
      src="https://picsum.photos/seed/hero/1920/1080"
      alt={`${business.name} - ${business.tagline}`}
      class="w-full h-full object-cover"
      loading="eager"
      style="animation: subtle-zoom 1.2s var(--ease-out-expo) both"
    />
    <!-- Multi-layer gradient overlay for depth -->
    <div class="absolute inset-0 bg-gradient-to-b from-secondary/70 via-secondary/50 to-secondary/80"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-secondary/60 via-transparent to-transparent"></div>
  </div>

  <!-- Subtle decorative element -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent z-10"></div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8 lg:px-10 py-32 md:py-40">
    <div class="max-w-2xl">
      <!-- Accent line -->
      <div class="hero-animate w-12 h-0.5 bg-primary mb-8 rounded-full"></div>

      <h1 class="hero-animate hero-animate-delay-1 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-heading text-white leading-[1.1] tracking-tight mb-6">
        {business.name}
      </h1>

      <p class="hero-animate hero-animate-delay-2 text-lg sm:text-xl md:text-2xl text-white/75 mb-12 leading-relaxed max-w-lg font-light">
        {business.tagline}
      </p>

      <div class="hero-animate hero-animate-delay-3 flex flex-col sm:flex-row gap-4">
        <a
          href={`tel:${business.phone}`}
          class="btn-primary inline-flex items-center justify-center gap-2.5 bg-primary text-white px-8 py-4 rounded-full text-base font-semibold hover:bg-primary-light tracking-wide"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Varaa aika
        </a>
        <a
          href="/#palvelut"
          class="inline-flex items-center justify-center gap-2.5 text-white/90 border border-white/20 px-8 py-4 rounded-full text-base font-medium hover:bg-white/10 hover:border-white/30 transition-all duration-400"
          style="transition-timing-function: var(--ease-out-expo); backdrop-filter: blur(8px)"
        >
          Palvelumme
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 hidden md:flex flex-col items-center gap-2 opacity-60">
    <div class="w-5 h-8 rounded-full border-2 border-white/40 flex justify-center pt-1.5">
      <div class="w-1 h-2 bg-white/60 rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
