---
import siteConfig from "../../site.config";

const { business } = siteConfig;
---

<section class="relative bg-secondary overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="https://picsum.photos/seed/hero/1920/1080"
      alt={`${business.name} - ${business.tagline}`}
      class="w-full h-full object-cover opacity-30"
      loading="eager"
    />
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 lg:py-44">
    <div class="max-w-2xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading text-white mb-6 leading-tight">
        {business.name}
      </h1>
      <p class="text-xl md:text-2xl text-gray-200 mb-10 leading-relaxed">
        {business.tagline}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={`tel:${business.phone}`}
          class="inline-flex items-center justify-center gap-2 bg-primary text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-primary-light transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Varaa aika
        </a>
        <a
          href="/#palvelut"
          class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur text-white border border-white/30 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white/20 transition-colors"
        >
          Palvelumme
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
