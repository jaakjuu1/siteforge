---
import siteConfig from "../../site.config";

const { testimonials, features } = siteConfig;
if (!features.testimonials) return;
---

<section id="arvostelut" class="section-padding bg-gray-50/50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10">
    <div class="text-center mb-16 md:mb-20 reveal">
      <span class="inline-block text-sm font-semibold text-primary tracking-widest uppercase mb-4">
        Arvostelut
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading text-secondary mb-5">
        Asiakkaidemme kokemuksia
      </h2>
      <div class="divider-gradient w-24 mx-auto mb-6"></div>
      <p class="text-lg text-gray-500 max-w-xl mx-auto leading-relaxed">
        Lue mita asiakkaamme kertovat meista
      </p>
    </div>

    <!-- Masonry-style offset grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        testimonials.map((testimonial, i) => (
          <div
            class={`reveal reveal-delay-${Math.min(i + 1, 4)} group bg-white rounded-2xl p-7 lg:p-8 border border-gray-100/80 card-hover ${i % 2 === 1 ? "lg:mt-8" : ""}`}
            style={`box-shadow: var(--shadow-sm)`}
          >
            <!-- Quote mark -->
            <div class="mb-5">
              <svg class="w-8 h-8 text-primary/15" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
            </div>

            <!-- Stars with animation -->
            <div class="flex gap-1 mb-5">
              {Array.from({ length: 5 }).map((_, starIdx) => (
                <svg
                  class={`w-4.5 h-4.5 star-animate ${starIdx < testimonial.rating ? "text-amber-400" : "text-gray-200"}`}
                  style={`animation-delay: ${starIdx * 0.08 + i * 0.15}s`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote text -->
            <p class="text-gray-600 mb-6 leading-relaxed text-[0.95rem]">
              &ldquo;{testimonial.text}&rdquo;
            </p>

            <!-- Author -->
            <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                <span class="text-sm font-bold text-primary">
                  {testimonial.name.charAt(0)}
                </span>
              </div>
              <span class="font-semibold text-secondary text-sm">{testimonial.name}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
