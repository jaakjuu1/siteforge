---
import { getCollection } from "astro:content";
import siteConfig from "../../site.config";

if (!siteConfig.features.blog) return;

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

{
  posts.length > 0 && (
    <section class="section-padding bg-gray-50/50">
      <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10">
        <div class="text-center mb-16 md:mb-20 reveal">
          <span class="inline-block text-sm font-semibold text-primary tracking-widest uppercase mb-4">
            Blogi
          </span>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-heading text-secondary mb-5">
            Blogi
          </h2>
          <div class="divider-gradient w-24 mx-auto mb-6" />
          <p class="text-lg text-gray-500 max-w-xl mx-auto leading-relaxed">
            Vinkkeja ja inspiraatiota hiustenhoitoon
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              class={`reveal reveal-delay-${Math.min(i + 1, 3)} group card-hover bg-white rounded-2xl overflow-hidden border border-gray-100/80`}
              style="box-shadow: var(--shadow-sm)"
            >
              {post.data.image && (
                <div class="aspect-video overflow-hidden relative">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-105"
                    style="transition-timing-function: var(--ease-out-expo)"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400" />
                </div>
              )}
              <div class="p-7">
                <div class="inline-flex items-center px-3 py-1 bg-primary/8 rounded-full mb-4">
                  <time class="text-xs font-medium text-primary" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString("fi-FI", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
                <h3 class="text-xl font-bold font-heading text-secondary mb-3 group-hover:text-primary transition-colors duration-300 leading-snug">
                  {post.data.title}
                </h3>
                <p class="text-gray-500 line-clamp-3 text-[0.95rem] leading-relaxed">{post.data.description}</p>

                <div class="mt-5 flex items-center gap-2 text-sm font-medium text-primary opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-0 group-hover:translate-x-1" style="transition-timing-function: var(--ease-out-expo)">
                  Lue lisaa
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-14 reveal">
          <a
            href="/blog"
            class="inline-flex items-center gap-2.5 text-primary font-semibold hover:text-primary-light transition-colors duration-300 group/link"
          >
            Katso kaikki kirjoitukset
            <svg
              class="w-5 h-5 transition-transform duration-300 group-hover/link:translate-x-1"
              style="transition-timing-function: var(--ease-out-expo)"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"
              />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )
}
