---
import siteConfig from "../../site.config";

const { business, features } = siteConfig;
---

<section id="yhteystiedot" class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold font-heading text-secondary mb-4">
        Ota yhteytta
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Varaa aikasi tai kysy lisatietoja - otamme mielellaamme yhteytta!
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      {
        features.contactForm && (
          <div>
            <form class="space-y-6" action="#" method="POST">
              <div>
                <label
                  for="name"
                  class="block text-sm font-medium text-secondary mb-2"
                >
                  Nimi
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                  placeholder="Etunimi Sukunimi"
                />
              </div>
              <div>
                <label
                  for="email"
                  class="block text-sm font-medium text-secondary mb-2"
                >
                  Sahkoposti
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                  placeholder="nimi@esimerkki.fi"
                />
              </div>
              <div>
                <label
                  for="phone"
                  class="block text-sm font-medium text-secondary mb-2"
                >
                  Puhelin
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                  placeholder="+358 40 123 4567"
                />
              </div>
              <div>
                <label
                  for="message"
                  class="block text-sm font-medium text-secondary mb-2"
                >
                  Viesti
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors resize-none"
                  placeholder="Kirjoita viestisi tahan..."
                />
              </div>
              <button
                type="submit"
                class="w-full bg-primary text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-light transition-colors"
              >
                Laheta viesti
              </button>
            </form>
          </div>
        )
      }

      <div class={features.contactForm ? "" : "lg:col-span-2 max-w-lg mx-auto"}>
        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-secondary mb-1">Osoite</h3>
              <p class="text-gray-600">
                {business.address.street}<br />
                {business.address.zip} {business.address.city}
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-secondary mb-1">Puhelin</h3>
              <a href={`tel:${business.phone}`} class="text-primary hover:text-primary-light transition-colors">
                {business.phone}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-secondary mb-1">Sahkoposti</h3>
              <a href={`mailto:${business.email}`} class="text-primary hover:text-primary-light transition-colors">
                {business.email}
              </a>
            </div>
          </div>

          {
            features.googleMaps && (
              <div class="mt-8 rounded-xl overflow-hidden shadow-sm border border-gray-100">
                <iframe
                  src={`https://maps.google.com/maps?q=${encodeURIComponent(`${business.address.street}, ${business.address.zip} ${business.address.city}`)}&output=embed`}
                  width="100%"
                  height="300"
                  style="border:0"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`${business.name} sijainti kartalla`}
                />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
